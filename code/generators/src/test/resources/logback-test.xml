<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- OpenApiGenerator Logger -->
  <appender name="OPEN_API_GENERATOR_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <immediateFlush>true</immediateFlush>
    <encoder>
      <pattern>%m%n</pattern>
    </encoder>
  </appender>

  <logger name="OpenApiGenerator" level="INFO" additivity="false">
    <appender-ref ref="OPEN_API_GENERATOR_STDOUT"/>
  </logger>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <immediateFlush>false</immediateFlush>
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} | %5p | %-20.20logger{20} | %m%n
      </pattern>
    </encoder>
  </appender>

  <appender name="file" class="ch.qos.logback.core.FileAppender">
    <file>target/karate-tools.log</file>
    <append>true</append>
    <encoder>
      <pattern>%d{yyyy-MM-dd} %d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="karate.org.thymeleaf" level="ERROR" />
  <logger name="org.thymeleaf" level="ERROR" />
  <logger name="io.karatelabs" level="INFO" />
  <logger name="dev.inditex.karate" level="DEBUG" />

  <!-- Karate 2.x SLF4J categories -->
  <!-- karate.runtime:  Feature/scenario lifecycle, step execution, suite orchestration -->
  <logger name="karate.runtime" level="INFO" />
  <!-- karate.http:     HTTP client - request/response bodies, headers, retries -->
  <logger name="karate.http" level="INFO" />
  <!-- karate.mock:     Mock server - incoming requests, matched scenarios, responses -->
  <logger name="karate.mock" level="INFO" />
  <!-- karate.server:   Embedded HTTP server - request/response logs -->
  <logger name="karate.server" level="INFO" />
  <!-- karate.scenario: User output - print, karate.log(), scenario-scoped messages -->
  <logger name="karate.scenario" level="INFO" />
  <!-- karate.console:  CLI console output - summary, colors, progress -->
  <logger name="karate.console" level="INFO" />

  <root level="info">
    <appender-ref ref="STDOUT" />
    <appender-ref ref="file" />
  </root>

</configuration>
